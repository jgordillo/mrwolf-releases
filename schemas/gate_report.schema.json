{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MRWOLF Gate Report",
  "type": "object",
  "required": ["stages", "overall_status", "durations"],
  "properties": {
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {"type": "string"},
          "status": {"type": "string"}
        }
      }
    },
    "overall_status": {"type": "string", "enum": ["PASS", "FAIL"]},
    "durations": {"type": "object"}
  }
}
